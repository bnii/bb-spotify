#!/usr/bin/env bb

(ns bb-spotify
  (:require [babashka.http-client :as http]
            [cheshire.core :as json]
            [babashka.fs :as fs]
            [babashka.process :as proc]
            [clojure.string :as str]
            [clojure.edn :as edn]
            [org.httpkit.server :as server])
  (:import [java.security MessageDigest SecureRandom]
           [java.util Base64]))

;; ── Constants ──────────────────────────────────────────────────────────────────

(def config-dir (str (fs/expand-home "~/.config/bb-spotify")))
(def tokens-file (str config-dir "/tokens.edn"))
(def redirect-uri "http://127.0.0.1:12983/callback")
(def auth-url "https://accounts.spotify.com/authorize")
(def token-url "https://accounts.spotify.com/api/token")
(def api-base "https://api.spotify.com/v1")
(def scopes "user-read-private playlist-read-private playlist-modify-public playlist-modify-private user-read-playback-state user-modify-playback-state")

(def config-file (str config-dir "/config.edn"))

(defn load-config []
  (when (fs/exists? config-file)
    (edn/read-string (slurp config-file))))

(defn save-config! [m]
  (fs/create-dirs config-dir)
  (spit config-file (pr-str (merge (load-config) m))))

(defn client-id []
  (or (System/getenv "SPOTIFY_CLIENT_ID")
      (:client-id (load-config))
      (do (println "Error: No client ID configured.")
          (println "Run: spotify auth <client-id>")
          (println "Or:  export SPOTIFY_CLIENT_ID=\"your_client_id_here\"")
          (throw (ex-info "" {:babashka/exit 1})))))

;; ── PKCE Helpers ───────────────────────────────────────────────────────────────

(defn random-bytes [n]
  (let [bytes (byte-array n)]
    (.nextBytes (SecureRandom.) bytes)
    bytes))

(defn base64url [^bytes bs]
  (-> (Base64/getUrlEncoder)
      (.withoutPadding)
      (.encodeToString bs)))

(defn code-verifier []
  (base64url (random-bytes 32)))

(defn code-challenge [verifier]
  (let [digest (MessageDigest/getInstance "SHA-256")
        hash (.digest digest (.getBytes verifier "US-ASCII"))]
    (base64url hash)))

;; ── Token Management ──────────────────────────────────────────────────────────

(defn load-tokens []
  (when (fs/exists? tokens-file)
    (edn/read-string (slurp tokens-file))))

(defn save-tokens! [tokens]
  (fs/create-dirs config-dir)
  (spit tokens-file (pr-str tokens)))

(defn tokens-expired? [tokens]
  (let [expires-at (:expires-at tokens 0)]
    (< expires-at (+ (System/currentTimeMillis) 60000))))

(defn refresh-tokens! [tokens]
  (let [form-body (str "grant_type=refresh_token"
                       "&refresh_token=" (java.net.URLEncoder/encode (:refresh-token tokens) "UTF-8")
                       "&client_id=" (java.net.URLEncoder/encode (client-id) "UTF-8"))
        resp (http/post token-url
               {:body    form-body
                :headers {"Content-Type" "application/x-www-form-urlencoded"}
                :throw   false})
        body (when (and (:body resp) (not (str/blank? (:body resp))))
               (json/parse-string (:body resp) true))]
    (if (:access_token body)
      (let [new-tokens {:access-token  (:access_token body)
                        :refresh-token (or (:refresh_token body) (:refresh-token tokens))
                        :expires-at    (+ (System/currentTimeMillis) (* (:expires_in body) 1000))}]
        (save-tokens! new-tokens)
        new-tokens)
      (do (println "Token refresh failed:" (:error body) "-" (:error_description body))
          (println "Run: spotify auth")
          (throw (ex-info "" {:babashka/exit 1}))))))

(defn get-access-token! []
  (let [tokens (load-tokens)]
    (when-not tokens
      (println "Not authenticated. Run: spotify auth")
      (throw (ex-info "" {:babashka/exit 1})))
    (let [tokens (if (tokens-expired? tokens)
                   (refresh-tokens! tokens)
                   tokens)]
      (:access-token tokens))))

;; ── OAuth Auth Flow ───────────────────────────────────────────────────────────

(defn auth! [args]
  (when-let [cid-arg (first args)]
    (save-config! {:client-id cid-arg})
    (println "Client ID saved."))
  (let [verifier  (code-verifier)
        challenge (code-challenge verifier)
        cid       (client-id)
        state     (base64url (random-bytes 16))
        result    (promise)
        auth-uri  (str auth-url "?"
                       "client_id=" cid
                       "&response_type=code"
                       "&redirect_uri=" (java.net.URLEncoder/encode redirect-uri "UTF-8")
                       "&scope=" (java.net.URLEncoder/encode scopes "UTF-8")
                       "&code_challenge_method=S256"
                       "&code_challenge=" challenge
                       "&state=" state)
        handler   (fn [req]
                    (if (not= (:uri req) "/callback")
                      {:status 404 :body "Not found"}
                      (let [params (into {}
                                    (map (fn [p]
                                           (let [[k v] (str/split p #"=" 2)]
                                             [k (java.net.URLDecoder/decode (or v "") "UTF-8")]))
                                         (str/split (or (:query-string req) "") #"&")))]
                        (if (get params "error")
                          (do (deliver result {:error (get params "error")})
                              {:status 200 :body "Authorization denied. You can close this window."})
                          (do (deliver result {:code (get params "code")})
                              {:status 200 :body "Authorization successful! You can close this window."})))))
        stop-fn   (server/run-server handler {:ip "127.0.0.1" :port 12983})]
    (println "Opening Spotify authorization in browser...")
    (proc/shell {:out :inherit :err :inherit} "open" auth-uri)
    (println "Waiting for callback on" redirect-uri "...")
    (let [res (deref result 120000 {:error "timeout"})]
      (stop-fn)
      (if (:error res)
        (do (println "Auth failed:" (:error res))
            (throw (ex-info "" {:babashka/exit 1})))
        ;; Exchange code for tokens
        (let [form-body (str "grant_type=authorization_code"
                             "&code=" (java.net.URLEncoder/encode (:code res) "UTF-8")
                             "&redirect_uri=" (java.net.URLEncoder/encode redirect-uri "UTF-8")
                             "&client_id=" (java.net.URLEncoder/encode cid "UTF-8")
                             "&code_verifier=" (java.net.URLEncoder/encode verifier "UTF-8"))
              resp (http/post token-url
                     {:body    form-body
                      :headers {"Content-Type" "application/x-www-form-urlencoded"}
                      :throw   false})
              body (when (and (:body resp) (not (str/blank? (:body resp))))
                     (json/parse-string (:body resp) true))]
          (if (:access_token body)
            (let [tokens {:access-token  (:access_token body)
                          :refresh-token (:refresh_token body)
                          :expires-at    (+ (System/currentTimeMillis) (* (:expires_in body) 1000))}]
              (save-tokens! tokens)
              (println "Auth successful! Tokens saved to" tokens-file))
            (do (println "Token exchange failed:" (:error body) "-" (:error_description body))
                (throw (ex-info "" {:babashka/exit 1})))))))))

;; ── API Client ────────────────────────────────────────────────────────────────

(defn api!
  ([method path] (api! method path nil))
  ([method path opts]
   (let [token (get-access-token!)
         url   (if (str/starts-with? path "http") path (str api-base path))
         resp  (http/request
                 (merge {:method  method
                         :uri     url
                         :headers {"Authorization" (str "Bearer " token)
                                   "Content-Type"  "application/json"}
                         :throw   false}
                        opts))
         raw   (:body resp)
         body  (when (and raw (not (str/blank? raw)) (str/starts-with? (str/triml raw) "{"))
                 (json/parse-string raw true))]
     (if (<= 200 (:status resp) 299)
       body
       (do (println (str "API error: " (or (:error (:error body))
                                            (:message (:error body))
                                            (str "HTTP " (:status resp)))))
           (throw (ex-info "" {:babashka/exit 1})))))))

;; ── Commands ──────────────────────────────────────────────────────────────────

(defn cmd-search [args]
  (when (empty? args)
    (println "Usage: spotify search <query>")
    (throw (ex-info "" {:babashka/exit 1})))
  (let [query (str/join " " args)
        resp  (api! :get (str "/search?type=track&limit=10&q="
                              (java.net.URLEncoder/encode query "UTF-8")))
        tracks (get-in resp [:tracks :items])]
    (if (empty? tracks)
      (println "No results found.")
      (do
        (println (format "%-5s %-40s %-25s %s" "#" "Track" "Artist" "URI"))
        (println (apply str (repeat 100 "-")))
        (doseq [[i track] (map-indexed vector tracks)]
          (println (format "%-5d %-40s %-25s %s"
                    (inc i)
                    (subs (:name track) 0 (min 40 (count (:name track))))
                    (subs (str/join ", " (map :name (:artists track)))
                          0 (min 25 (count (str/join ", " (map :name (:artists track))))))
                    (:uri track))))))))

(defn cmd-playlists []
  (let [resp  (api! :get "/me/playlists?limit=50")
        lists (:items resp)]
    (if (empty? lists)
      (println "No playlists found.")
      (do
        (println (format "%-40s %-10s %s" "Name" "Tracks" "ID"))
        (println (apply str (repeat 80 "-")))
        (doseq [pl lists]
          (println (format "%-40s %-10d %s"
                    (subs (:name pl) 0 (min 40 (count (:name pl))))
                    (get-in pl [:tracks :total] 0)
                    (:id pl))))))))

(defn cmd-playlist-create [args]
  (when (empty? args)
    (println "Usage: spotify playlist create <name>")
    (throw (ex-info "" {:babashka/exit 1})))
  (let [name  (str/join " " args)
        me    (api! :get "/me")
        resp  (api! :post (str "/users/" (:id me) "/playlists")
                {:body (json/generate-string {:name name :public false})})]
    (println "Created playlist:")
    (println "  Name:" (:name resp))
    (println "  ID:  " (:id resp))
    (println "  URI: " (:uri resp))))

(defn cmd-playlist-add [args]
  (when (< (count args) 2)
    (println "Usage: spotify playlist add <id> <uri> [uri...]")
    (throw (ex-info "" {:babashka/exit 1})))
  (let [id   (first args)
        uris (rest args)]
    (api! :post (str "/playlists/" id "/tracks")
      {:body (json/generate-string {:uris (vec uris)})})
    (println (str "Added " (count uris) " track(s) to playlist " id))))

(defn cmd-playlist-remove [args]
  (when (< (count args) 2)
    (println "Usage: spotify playlist remove <id> <uri> [uri...]")
    (throw (ex-info "" {:babashka/exit 1})))
  (let [id   (first args)
        uris (rest args)]
    (api! :delete (str "/playlists/" id "/tracks")
      {:body (json/generate-string {:tracks (mapv (fn [u] {:uri u}) uris)})})
    (println (str "Removed " (count uris) " track(s) from playlist " id))))

(defn cmd-playlist-show [args]
  (when (empty? args)
    (println "Usage: spotify playlist show <id>")
    (throw (ex-info "" {:babashka/exit 1})))
  (let [id   (first args)
        resp (api! :get (str "/playlists/" id "/tracks?limit=100"))
        items (:items resp)]
    (if (empty? items)
      (println "Playlist is empty.")
      (do
        (println (format "%-5s %-40s %s" "#" "Track" "Artist"))
        (println (apply str (repeat 75 "-")))
        (doseq [[i item] (map-indexed vector items)]
          (let [track (:track item)]
            (println (format "%-5d %-40s %s"
                      (inc i)
                      (subs (:name track) 0 (min 40 (count (:name track))))
                      (str/join ", " (map :name (:artists track)))))))))))

(defn cmd-devices []
  (let [resp  (api! :get "/me/player/devices")
        devs  (:devices resp)]
    (if (empty? devs)
      (println "No devices found. Open Spotify on a device first.")
      (do
        (println (format "%-3s %-30s %-15s %s" "" "Name" "Type" "ID"))
        (println (apply str (repeat 80 "-")))
        (doseq [d devs]
          (println (format "%-3s %-30s %-15s %s"
                    (if (:is_active d) "*" "")
                    (subs (:name d) 0 (min 30 (count (:name d))))
                    (:type d)
                    (:id d))))))))

(defn resolve-device [name-or-id]
  (let [resp (api! :get "/me/player/devices")
        devs (:devices resp)
        needle (str/lower-case name-or-id)
        match (or (first (filter #(= (:id %) name-or-id) devs))
                  (first (filter #(str/includes? (str/lower-case (:name %)) needle) devs)))]
    (when-not match
      (println (str "No device matching \"" name-or-id "\" found."))
      (println "Available devices:")
      (doseq [d devs]
        (println (str "  " (:name d) " (" (:type d) ") — " (:id d))))
      (throw (ex-info "" {:babashka/exit 1})))
    match))

(defn cmd-device [args]
  (when (empty? args)
    (println "Usage: spotify device <name-or-id>")
    (println "       spotify device <name-or-id> play")
    (println "Run `spotify devices` to list available devices.")
    (throw (ex-info "" {:babashka/exit 1})))
  (let [device (resolve-device (first args))
        play?  (= "play" (second args))]
    (api! :put "/me/player"
      {:body (json/generate-string {:device_ids [(:id device)] :play play?})})
    (println (str "Transferred playback to " (:name device)
                  (when play? " (playing)")))))

(defn cmd-play [args]
  (if (empty? args)
    (do (api! :put "/me/player/play" {:body "{}"})
        (println "Resumed playback."))
    (let [uri (first args)]
      (if (str/includes? uri "track")
        (api! :put "/me/player/play"
          {:body (json/generate-string {:uris [uri]})})
        (api! :put "/me/player/play"
          {:body (json/generate-string {:context_uri uri})}))
      (println "Playing:" uri))))

(defn cmd-pause []
  (api! :put "/me/player/pause")
  (println "Paused."))

(defn cmd-resume []
  (api! :put "/me/player/play")
  (println "Resumed."))

(defn cmd-next []
  (api! :post "/me/player/next")
  (println "Skipped to next track."))

(defn cmd-prev []
  (api! :post "/me/player/previous")
  (println "Went to previous track."))

(defn cmd-queue [args]
  (when (empty? args)
    (println "Usage: spotify queue <track-uri>")
    (throw (ex-info "" {:babashka/exit 1})))
  (let [uri (first args)]
    (api! :post (str "/me/player/queue?uri=" (java.net.URLEncoder/encode uri "UTF-8")))
    (println "Queued:" uri)))

(defn cmd-now []
  (let [resp (api! :get "/me/player/currently-playing")]
    (if (or (nil? resp) (nil? (:item resp)))
      (println "Nothing is currently playing.")
      (let [track (:item resp)]
        (println "Playing:")
        (println "  " (:name track) "-" (str/join ", " (map :name (:artists track))))
        (println "  Album:" (get-in track [:album :name]))
        (println "  URI:  " (:uri track))
        (println (str "  Progress: " (quot (:progress_ms resp) 1000) "s / "
                      (quot (:duration_ms track) 1000) "s"))))))

;; ── CLI Dispatch ──────────────────────────────────────────────────────────────

(defn usage []
  (println "bb-spotify — Babashka CLI for the Spotify Web API

USAGE
  spotify <command> [args]

SETUP
  spotify auth <client-id>    Save client ID and authenticate via browser OAuth (PKCE).
                              Get a client ID from https://developer.spotify.com/dashboard
                              Redirect URI must be set to: http://127.0.0.1:12983/callback
                              Tokens are stored in ~/.config/bb-spotify/tokens.edn
                              Client ID is stored in ~/.config/bb-spotify/config.edn
                              Alternatively set SPOTIFY_CLIENT_ID env var (takes precedence).

SEARCH
  spotify search <query>      Search tracks. Returns up to 10 results.
                              Output columns: #, Track, Artist, URI
                              Example: spotify search \"All Blues Miles Davis\"

PLAYLISTS
  spotify playlists                       List all user playlists. Output: Name, Tracks, ID
  spotify playlist create <name>          Create a new private playlist. Returns ID and URI.
  spotify playlist show <id>              List tracks in a playlist. Output: #, Track, Artist
  spotify playlist add <id> <uri>...      Add one or more tracks by URI. Batch supported.
  spotify playlist remove <id> <uri>...   Remove one or more tracks by URI.

DEVICES
  spotify devices             List available devices (name, type, ID). Active device marked *.
  spotify device <id>         Transfer playback to device (keeps current play state).
  spotify device <id> play    Transfer playback and force start playing.

PLAYBACK (requires an active Spotify device)
  spotify play [uri]          With no args: resume playback.
                              With a track URI (spotify:track:...): play that track.
                              With a playlist URI (spotify:playlist:...): play that playlist.
  spotify pause               Pause playback.
  spotify resume              Resume playback (alias for play with no args).
  spotify next                Skip to next track.
  spotify prev                Go to previous track.
  spotify queue <uri>         Add a track URI to the playback queue.
  spotify now                 Show currently playing track, album, URI, and progress.

URI FORMAT
  Track:    spotify:track:<id>       (from search results)
  Playlist: spotify:playlist:<id>    (from playlists command)

COMMON WORKFLOWS
  # Search and add tracks to a playlist:
  spotify search \"Blue Monk Thelonious Monk\"
  spotify playlist add <playlist-id> spotify:track:<track-id>

  # Create playlist, add multiple tracks, then play:
  spotify playlist create \"My Playlist\"
  spotify playlist add <id> spotify:track:aaa spotify:track:bbb spotify:track:ccc
  spotify play spotify:playlist:<id>

ERRORS
  \"Not authenticated\"        → Run: spotify auth <client-id>
  \"No active device found\"   → Run: spotify devices, then: spotify device <id> play
  \"Restriction violated\"     → Action not possible in current state (e.g. prev with no history)."))

(let [args *command-line-args*
      cmd  (first args)
      rest-args (rest args)]
  (case cmd
    "auth"     (auth! rest-args)
    "search"   (cmd-search rest-args)
    "playlists" (cmd-playlists)
    "playlist" (let [subcmd (first rest-args)
                     sub-args (rest rest-args)]
                 (case subcmd
                   "create" (cmd-playlist-create sub-args)
                   "add"    (cmd-playlist-add sub-args)
                   "remove" (cmd-playlist-remove sub-args)
                   "show"   (cmd-playlist-show sub-args)
                   (do (when subcmd
                         (println "Unknown playlist command:" subcmd))
                       (usage)
                       (throw (ex-info "" {:babashka/exit 1})))))
    "devices"  (cmd-devices)
    "device"   (cmd-device rest-args)
    "play"     (cmd-play rest-args)
    "pause"    (cmd-pause)
    "resume"   (cmd-resume)
    "next"     (cmd-next)
    "prev"     (cmd-prev)
    "queue"    (cmd-queue rest-args)
    "now"      (cmd-now)
    (do (usage)
        (when cmd (throw (ex-info "" {:babashka/exit 1}))))))
